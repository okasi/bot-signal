{
  "name": "is-suspicious-client",
  "version": "1.4.0",
  "description": "Detect headless browsers, automation frameworks, and other suspicious client signals in the browser",
  "license": "MIT",
  "author": "okasi",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "update:ip-data": "tsx scripts/update-ip-data.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bot-detection",
    "headless",
    "selenium",
    "webdriver",
    "phantomjs",
    "webgpu",
    "fingerprint",
    "anti-bot"
  ],
  "dependencies": {
    "doc999tor-fast-geoip": "^1.1.443",
    "ipaddr.js": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@webgpu/types": "^0.1.60",
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "undici": "^7.28.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
